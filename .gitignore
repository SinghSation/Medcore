# -----------------------------------------------------------------------------
# Medcore .gitignore
#
# This file is authoritative. Agents and contributors MUST NOT un-ignore any
# of the PHI, secret, or credential patterns below without an ADR.
# -----------------------------------------------------------------------------

# --- OS ----------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini

# --- IDE / editors -----------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.history/

# --- Node / JS / TS ----------------------------------------------------------
node_modules/
dist/
build/
.next/
.turbo/
.cache/
.parcel-cache/
*.tsbuildinfo
.pnpm-store/
.yarn/cache/
.yarn/install-state.gz

# --- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Java / JVM --------------------------------------------------------------
*.class
*.jar
*.war
*.ear
target/
.gradle/
# Kotlin incremental / daemon caches (written under module roots on build)
.kotlin/

# Gradle wrapper jars are explicitly tracked — they are part of the wrapper
# contract that makes ./gradlew self-bootstrap on a fresh clone.
!**/gradle/wrapper/gradle-wrapper.jar

# --- Go ----------------------------------------------------------------------
bin/
*.test
*.out

# --- Terraform / IaC ---------------------------------------------------------
# State, plan, and operator-supplied secrets stay local. Provider lockfile
# (`.terraform.lock.hcl`) IS committed — it pins provider checksums for
# reproducibility, per ADR-010 §2.2. The negation must come AFTER the
# parent ignore that would otherwise match.
.terraform/
.terraform.lock.hcl
!**/.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan
*.tfvars
!**/*.tfvars.example
crash.log
crash.*.log
override.tf
override.tf.json
# Bootstrap-only artifacts: the operator's `terraform output -json` dump,
# placed next to the bootstrap module after the first apply.
**/bootstrap-outputs.json
*_override.tf
*_override.tf.json

# --- Secrets & environment (NEVER COMMIT) ------------------------------------
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.crt
*.pfx
*.p12
*.keystore
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
.aws/
.gcp/
.azure/
service-account*.json
credentials.json
secrets.yaml
secrets.yml

# --- PHI / clinical data (NEVER COMMIT) --------------------------------------
# Developers MUST NOT place real or realistic patient data in the repo.
# Synthetic fixtures belong in a dedicated, reviewed location.
*.phi
*.phi.*
patients/
phi-fixtures/
*.hl7
*.ccda
*.ccd
*.ccr

# --- Local database dumps & backups (NEVER COMMIT) ---------------------------
# Never commit a production database dump. Even dev / test dumps often
# contain synthetic-but-realistic fixtures that belong in a reviewed location.
# Note: *.sql is intentionally NOT ignored — Flyway migrations must be tracked.
*.dump
*.pgdump
*.sql.gz
*.sql.bz2
*.sql.xz
*.backup
pgdump-*/

# --- Logs --------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Test / coverage ---------------------------------------------------------
coverage/
.nyc_output/
test-results/
playwright-report/
*.lcov

# --- Claude Code (agent toolchain) -------------------------------------------
# .claude/ is partially tracked — skills/ and agents/ are project-shared
# content. Per-user preferences and runtime locks must NOT be committed.
.claude/settings.json
.claude/settings.local.json
.claude/scheduled_tasks.lock

# --- Misc --------------------------------------------------------------------
tmp/
temp/
*.tmp
.cache
.local/

# Medcore — EditorConfig
# https://editorconfig.org
#
# This file is authoritative for baseline file formatting. Agents and
# contributors MUST NOT override these defaults without an ADR.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.{py,sh,bash}]
indent_size = 4

[Makefile]
indent_style = tab

[*.go]
indent_style = tab
indent_size = 4

[*.{yml,yaml,json,jsonc}]
indent_size = 2

[*.{tf,tfvars}]
indent_size = 2

[*.sql]
indent_size = 2

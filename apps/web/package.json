{
  "name": "@medcore/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Medcore frontend shell — React + TypeScript + Vite.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
